<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Check-in Hari Ini"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"
        android:background="#E8E8E8" />

    <!-- Subuh -->
    <LinearLayout
        android:id="@+id/row_subuh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="8dp">

        <TextView
            android:id="@+id/label_subuh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Subuh"
            android:textColor="#1A1A1A"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tepat_subuh"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="✓"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />

        <TextView
            android:id="@+id/qadha_subuh"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="Q"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />

        <TextView
            android:id="@+id/tidak_subuh"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="✗"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />
    </LinearLayout>

    <!-- Dzuhur -->
    <LinearLayout
        android:id="@+id/row_dzuhur"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="8dp">

        <TextView
            android:id="@+id/label_dzuhur"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dzuhur"
            android:textColor="#1A1A1A"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tepat_dzuhur"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="✓"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />

        <TextView
            android:id="@+id/qadha_dzuhur"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="Q"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />

        <TextView
            android:id="@+id/tidak_dzuhur"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="✗"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />
    </LinearLayout>

    <!-- Ashar -->
    <LinearLayout
        android:id="@+id/row_ashar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="8dp">

        <TextView
            android:id="@+id/label_ashar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ashar"
            android:textColor="#1A1A1A"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tepat_ashar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="✓"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />

        <TextView
            android:id="@+id/qadha_ashar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="Q"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />

        <TextView
            android:id="@+id/tidak_ashar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="✗"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />
    </LinearLayout>

    <!-- Maghrib -->
    <LinearLayout
        android:id="@+id/row_maghrib"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="8dp">

        <TextView
            android:id="@+id/label_maghrib"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Maghrib"
            android:textColor="#1A1A1A"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tepat_maghrib"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="✓"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />

        <TextView
            android:id="@+id/qadha_maghrib"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="Q"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />

        <TextView
            android:id="@+id/tidak_maghrib"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="✗"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />
    </LinearLayout>

    <!-- Isya -->
    <LinearLayout
        android:id="@+id/row_isya"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="8dp">

        <TextView
            android:id="@+id/label_isya"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Isya"
            android:textColor="#1A1A1A"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tepat_isya"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="✓"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />

        <TextView
            android:id="@+id/qadha_isya"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="Q"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />

        <TextView
            android:id="@+id/tidak_isya"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="✗"
            android:textSize="12sp"
            android:textColor="#999999"
            android:background="#E8E8E8" />
    </LinearLayout>

</LinearLayout>
