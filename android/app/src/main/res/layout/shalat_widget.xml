<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="6dp">

        <!-- Gold accent bar -->
        <TextView
            android:layout_width="3dp"
            android:layout_height="16dp"
            android:background="#C9A84C" />

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="Check-in Hari Ini"
            android:textColor="#0D1F16"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <TextView
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:background="#EEF4F0" />

    <!-- Subuh -->
    <LinearLayout
        android:id="@+id/row_subuh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:id="@+id/label_subuh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Subuh"
            android:textColor="#0D1F16"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tepat_subuh"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="✓"
            android:textSize="13sp"
            android:textColor="#1A5C38"
            android:textStyle="bold"
            android:background="@drawable/chip_tepat_unselected" />

        <TextView
            android:id="@+id/qadha_subuh"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="Q"
            android:textSize="13sp"
            android:textColor="#F57F17"
            android:textStyle="bold"
            android:background="@drawable/chip_qadha_unselected" />

        <TextView
            android:id="@+id/tidak_subuh"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="✗"
            android:textSize="13sp"
            android:textColor="#B00020"
            android:textStyle="bold"
            android:background="@drawable/chip_tidak_unselected" />
    </LinearLayout>

    <!-- Dzuhur -->
    <LinearLayout
        android:id="@+id/row_dzuhur"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:id="@+id/label_dzuhur"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dzuhur"
            android:textColor="#0D1F16"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tepat_dzuhur"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="✓"
            android:textSize="13sp"
            android:textColor="#1A5C38"
            android:textStyle="bold"
            android:background="@drawable/chip_tepat_unselected" />

        <TextView
            android:id="@+id/qadha_dzuhur"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="Q"
            android:textSize="13sp"
            android:textColor="#F57F17"
            android:textStyle="bold"
            android:background="@drawable/chip_qadha_unselected" />

        <TextView
            android:id="@+id/tidak_dzuhur"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="✗"
            android:textSize="13sp"
            android:textColor="#B00020"
            android:textStyle="bold"
            android:background="@drawable/chip_tidak_unselected" />
    </LinearLayout>

    <!-- Ashar -->
    <LinearLayout
        android:id="@+id/row_ashar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:id="@+id/label_ashar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ashar"
            android:textColor="#0D1F16"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tepat_ashar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="✓"
            android:textSize="13sp"
            android:textColor="#1A5C38"
            android:textStyle="bold"
            android:background="@drawable/chip_tepat_unselected" />

        <TextView
            android:id="@+id/qadha_ashar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="Q"
            android:textSize="13sp"
            android:textColor="#F57F17"
            android:textStyle="bold"
            android:background="@drawable/chip_qadha_unselected" />

        <TextView
            android:id="@+id/tidak_ashar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="✗"
            android:textSize="13sp"
            android:textColor="#B00020"
            android:textStyle="bold"
            android:background="@drawable/chip_tidak_unselected" />
    </LinearLayout>

    <!-- Maghrib -->
    <LinearLayout
        android:id="@+id/row_maghrib"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:id="@+id/label_maghrib"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Maghrib"
            android:textColor="#0D1F16"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tepat_maghrib"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="✓"
            android:textSize="13sp"
            android:textColor="#1A5C38"
            android:textStyle="bold"
            android:background="@drawable/chip_tepat_unselected" />

        <TextView
            android:id="@+id/qadha_maghrib"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="Q"
            android:textSize="13sp"
            android:textColor="#F57F17"
            android:textStyle="bold"
            android:background="@drawable/chip_qadha_unselected" />

        <TextView
            android:id="@+id/tidak_maghrib"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="✗"
            android:textSize="13sp"
            android:textColor="#B00020"
            android:textStyle="bold"
            android:background="@drawable/chip_tidak_unselected" />
    </LinearLayout>

    <!-- Isya -->
    <LinearLayout
        android:id="@+id/row_isya"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:id="@+id/label_isya"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Isya"
            android:textColor="#0D1F16"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tepat_isya"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="✓"
            android:textSize="13sp"
            android:textColor="#1A5C38"
            android:textStyle="bold"
            android:background="@drawable/chip_tepat_unselected" />

        <TextView
            android:id="@+id/qadha_isya"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="Q"
            android:textSize="13sp"
            android:textColor="#F57F17"
            android:textStyle="bold"
            android:background="@drawable/chip_qadha_unselected" />

        <TextView
            android:id="@+id/tidak_isya"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="4dp"
            android:gravity="center"
            android:text="✗"
            android:textSize="13sp"
            android:textColor="#B00020"
            android:textStyle="bold"
            android:background="@drawable/chip_tidak_unselected" />
    </LinearLayout>

</LinearLayout>
